# API Gateway — Local Development Environment
# Copy to .env and fill in your values.
# In Docker the docker-compose.yml provides these automatically.

PORT=3000
NODE_ENV=development
JWT_SECRET=6fa315cc961a7bae9e4718ae1166539cd4581ec17e9878c8d9a2742f74b565a0dedf453acfb2f28ffead831cff84b5ecf286cc4ba8177dd8a8354c3c4844c099

# ── Upstream Services (local ports match docker-compose host bindings) ────────
AUTH_SERVICE_URL=http://localhost:8081
PRODUCT_SERVICE_URL=http://localhost:3001
INVENTORY_SERVICE_URL=http://localhost:3002
ORDER_SERVICE_URL=http://localhost:3003
REPAIR_SERVICE_URL=http://localhost:3004
LOYALTY_SERVICE_URL=http://localhost:3005
HR_SERVICE_URL=http://localhost:3006
WORKER_SERVICE_URL=http://localhost:8000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_secret@localhost:6379

# ── SMTP (used by gateway mailer) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com                # ← keep for Gmail
SMTP_PORT=587                           # ← keep for Gmail
SMTP_USER=umeshbandara08@gmail.com               # ⚠️ your Gmail address
SMTP_PASS=crbl kdpm ysah phzr        # ⚠️ Gmail App Password (see Step 7)
FROM_EMAIL=umeshbandara08@gmail.com            # display from address
ALERT_EMAIL=umeshbandara08@gmail.com             # where low-stock alerts go

# ── Cloudflare Turnstile (CAPTCHA on login) ───────────────────────────────────
CF_TURNSTILE_SECRET_KEY=
