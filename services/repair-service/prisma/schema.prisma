// TechMo Repair Service – Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model RepairTicket {
  id           String       @id @default(uuid())
  ticketNumber String       @unique
  customerId   String?
  customerName String
  customerPhone String
  deviceBrand  String
  deviceModel  String
  imei         String?
  issueDescription String
  technicianId String?      // userId
  status       RepairStatus @default(PENDING_DIAGNOSIS)
  estimatedCost Decimal?    @db.Decimal(12, 2)
  finalCost    Decimal?     @db.Decimal(12, 2)
  qrToken      String       @unique  // public QR tracking token
  receivedAt   DateTime     @default(now())
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  statusHistory       RepairStatusHistory[]
  parts               RepairPart[]
  photos              RepairPhoto[]
  signatureUrl        String?      // base64 data-url embedded in completion receipt
  completionReceiptUrl String?     // Cloudinary URL of signed receipt PDF
  warrantyTermsUrl    String?      // Cloudinary URL of warranty terms PDF page
  completionVideoUrl  String?      // Cloudinary URL of proof-of-function video

  // Courier / shipping tracking
  courierTrackingNumber String?    // carrier tracking number (e.g. DHL waybill)
  courierCarrier        String?    // 'dhl' | 'slpost' | '17track' | 'fedex'
  courierStatus         String?    // last known status text from carrier
  courierUpdatedAt      DateTime?  // when we last polled the carrier

  @@map("repair_tickets")
}

model RepairPhoto {
  id           String         @id @default(uuid())
  ticketId     String
  ticket       RepairTicket   @relation(fields: [ticketId], references: [id])
  phase        PhotoPhase
  cloudinaryUrl String
  publicId     String
  uploadedBy   String         // userId
  caption      String?
  createdAt    DateTime       @default(now())

  @@map("repair_photos")
}

enum PhotoPhase {
  BEFORE
  DURING
  AFTER
}

model RepairStatusHistory {
  id           String       @id @default(uuid())
  ticketId     String
  ticket       RepairTicket @relation(fields: [ticketId], references: [id])
  status       RepairStatus
  updatedBy    String       // userId
  notes        String?
  createdAt    DateTime     @default(now())  // immutable

  @@map("repair_status_history")
}

model RepairPart {
  id          String       @id @default(uuid())
  ticketId    String
  ticket      RepairTicket @relation(fields: [ticketId], references: [id])
  productId   String
  productName String
  sku         String
  quantity    Int
  unitCost    Decimal      @db.Decimal(12, 2)
  createdAt   DateTime     @default(now())

  @@map("repair_parts")
}

enum RepairStatus {
  RECEIVED
  PENDING_DIAGNOSIS
  AWAITING_PARTS
  UNDER_REPAIR
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}
