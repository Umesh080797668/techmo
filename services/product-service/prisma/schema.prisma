// TechMo Product Service – Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DeviceModel {
  id           String   @id @default(uuid())
  brand        String
  model        String
  variant      String?
  releaseYear  Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  compatibilities PartCompatibility[]

  @@unique([brand, model, variant])
  @@map("device_models")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  products Product[]

  @@map("categories")
}

model Product {
  id              String   @id @default(uuid())
  sku             String   @unique
  name            String
  description     String?
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  productType     ProductType @default(ACCESSORY)
  brand           String?
  barcode         String?  @unique
  costPrice       Decimal  @db.Decimal(12, 2)
  sellingPrice    Decimal  @db.Decimal(12, 2)
  warrantyMonths  Int      @default(0)
  requiresImei    Boolean  @default(false)
  requiresSerial  Boolean  @default(false)
  isActive        Boolean  @default(true)
  images          String[]
  tags            String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  variants        ProductVariant[]
  compatibilities PartCompatibility[]
  imeiRecords     ImeiRecord[]
  pricingRules    PricingRule[]

  @@map("products")
}

model ProductVariant {
  id           String   @id @default(uuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  variantName  String   // e.g. "Color: Black", "Storage: 128GB"
  sku          String   @unique
  barcode      String?  @unique
  costPrice    Decimal? @db.Decimal(12, 2)
  sellingPrice Decimal? @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("product_variants")
}

model PartCompatibility {
  id            String      @id @default(uuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  deviceModelId String
  deviceModel   DeviceModel @relation(fields: [deviceModelId], references: [id])
  notes         String?
  createdAt     DateTime    @default(now())
  votes         CompatibilityVote[]

  @@unique([productId, deviceModelId])
  @@map("part_compatibility")
}

/// Crowdsourced up/down votes on part↔device compatibility mappings.
/// Staff can upvote (confirms works), downvote (confirms broken), or add notes.
model CompatibilityVote {
  id              String           @id @default(uuid())
  compatibilityId String
  compatibility   PartCompatibility @relation(fields: [compatibilityId], references: [id], onDelete: Cascade)
  staffId         String
  vote            CompatibilityVoteType
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([compatibilityId, staffId])
  @@map("compatibility_votes")
}

enum CompatibilityVoteType {
  UP
  DOWN
}

model ImeiRecord {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  imei        String   @unique
  serialNumber String? @unique
  color       String?
  storage     String?
  status      ImeiStatus @default(IN_STOCK)
  soldAt      DateTime?
  orderId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warrantyRecords WarrantyClaim[]

  @@map("imei_records")
}

model PricingRule {
  id          String      @id @default(uuid())
  productId   String?
  product     Product?    @relation(fields: [productId], references: [id])
  ruleType    PricingRuleType
  name        String
  description String?
  discountPct Decimal?    @db.Decimal(5, 2)
  discountAmt Decimal?    @db.Decimal(12, 2)
  minQty      Int?
  startsAt    DateTime?
  endsAt      DateTime?
  requiresManagerPin Boolean @default(false)
  isActive    Boolean     @default(true)
  comboRules  Json?       // JSON array of product conditions for combo
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("pricing_rules")
}

model WarrantyClaim {
  id           String        @id @default(uuid())
  imeiRecordId String
  imeiRecord   ImeiRecord    @relation(fields: [imeiRecordId], references: [id])
  claimedById  String        // userId from auth service
  status       WarrantyStatus @default(PENDING)
  claimType    String        @default("WARRANTY_REPAIR") // WARRANTY_REPAIR | WARRANTY_REPLACEMENT | SUPPLIER_RETURN
  issue        String
  resolution   String?
  rejectedReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("warranty_claims")
}

enum ProductType {
  PHONE
  ACCESSORY
  SPARE_PART
  SERVICE
}

enum ImeiStatus {
  IN_STOCK
  SOLD
  REPAIRED
  RETURNED
  SCRAPPED
}

enum PricingRuleType {
  DISCOUNT_PERCENT
  DISCOUNT_AMOUNT
  COMBO_DISCOUNT
  TIME_BASED
  BULK
}

enum WarrantyStatus {
  PENDING
  APPROVED
  REJECTED
  RESOLVED
}

/// Generic key-value store for runtime configuration (e.g. manager_pin).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
