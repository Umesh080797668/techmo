---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const allGuides = await getCollection('guides');

const sorted = allGuides.sort(
  (a, b) => new Date(b.data.updatedAt).getTime() - new Date(a.data.updatedAt).getTime()
);

const difficulties = ['Beginner', 'Intermediate', 'Advanced'] as const;

const difficultyColour: Record<string, string> = {
  Beginner:     'bg-green-100 text-green-800',
  Intermediate: 'bg-yellow-100 text-yellow-800',
  Advanced:     'bg-red-100 text-red-800',
};
---

<Layout
  title="Repair Knowledge Base"
  description="Step-by-step repair guides for iPhones, Samsung Galaxy, and more — written by TechMo's certified technicians."
>
  <Navbar />

  <main class="min-h-screen bg-gray-50">
    <!-- Hero -->
    <section class="bg-gradient-to-br from-blue-700 to-blue-900 text-white py-16 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <div class="text-5xl mb-4">🔧</div>
        <h1 class="text-4xl font-bold mb-3">Repair Knowledge Base</h1>
        <p class="text-blue-200 text-lg max-w-2xl mx-auto">
          Step-by-step guides written by TechMo's certified technicians.
          Transparent, honest, and free to read.
        </p>

        <!-- Search -->
        <div class="mt-8 max-w-xl mx-auto">
          <input
            id="kb-search"
            type="search"
            placeholder="Search guides… e.g. iPhone battery, Samsung screen"
            class="w-full px-5 py-3 rounded-xl text-gray-900 text-base shadow-lg focus:outline-none focus:ring-2 focus:ring-blue-400"
          />
        </div>
      </div>
    </section>

    <!-- Filter chips -->
    <section class="max-w-5xl mx-auto px-4 py-6 flex flex-wrap gap-2 items-center">
      <span class="text-sm text-gray-500 mr-1">Filter by difficulty:</span>
      <button
        data-filter="all"
        class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium bg-blue-600 text-white"
      >
        All
      </button>
      {difficulties.map(d => (
        <button
          data-filter={d}
          class={`filter-btn px-4 py-1.5 rounded-full text-sm font-medium border ${difficultyColour[d]}`}
        >
          {d}
        </button>
      ))}
    </section>

    <!-- Guide grid -->
    <section class="max-w-5xl mx-auto px-4 pb-16">
      <div id="guide-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {sorted.map(guide => (
          <a
            href={`/guides/${guide.slug}`}
            data-difficulty={guide.data.difficulty}
            data-title={guide.data.title.toLowerCase()}
            data-device={guide.data.device.toLowerCase()}
            class="guide-card bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow p-5 flex flex-col gap-3 border border-gray-100"
          >
            <div class="flex items-start justify-between gap-2">
              <h2 class="text-base font-semibold text-gray-900 leading-snug">{guide.data.title}</h2>
              <span class={`shrink-0 text-xs font-medium px-2 py-0.5 rounded-full ${difficultyColour[guide.data.difficulty]}`}>
                {guide.data.difficulty}
              </span>
            </div>

            <p class="text-sm text-gray-500">{guide.data.device}</p>

            <div class="mt-auto flex items-center gap-4 text-xs text-gray-400">
              <span>⏱ {guide.data.estimatedTime}</span>
              <span>🛠 {guide.data.tools.length} tools</span>
            </div>
          </a>
        ))}
      </div>

      <p id="no-results" class="hidden text-center text-gray-400 py-16 text-lg">
        No guides match your search. <a href="/contact" class="text-blue-600 underline">Request a guide →</a>
      </p>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const searchInput = document.getElementById('kb-search') as HTMLInputElement;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.guide-card');
  const noResults = document.getElementById('no-results')!;

  let activeFilter = 'all';
  let searchQuery = '';

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const difficulty = card.dataset.difficulty ?? '';
      const title = card.dataset.title ?? '';
      const device = card.dataset.device ?? '';

      const matchesDiff = activeFilter === 'all' || difficulty === activeFilter;
      const matchesSearch =
        searchQuery === '' ||
        title.includes(searchQuery) ||
        device.includes(searchQuery);

      if (matchesDiff && matchesSearch) {
        card.classList.remove('hidden');
        visible++;
      } else {
        card.classList.add('hidden');
      }
    });

    noResults.classList.toggle('hidden', visible > 0);
  }

  searchInput?.addEventListener('input', e => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
    applyFilters();
  });

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = btn.dataset.filter ?? 'all';
      filterBtns.forEach(b => {
        b.classList.toggle('bg-blue-600', b.dataset.filter === activeFilter);
        b.classList.toggle('text-white', b.dataset.filter === activeFilter);
      });
      applyFilters();
    });
  });
</script>
