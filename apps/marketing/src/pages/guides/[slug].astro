---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

interface Props {
  guide: CollectionEntry<'guides'>;
}

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await guide.render();

const difficultyColour: Record<string, string> = {
  Beginner:     'bg-green-100 text-green-800 border-green-200',
  Intermediate: 'bg-yellow-100 text-yellow-800 border-yellow-200',
  Advanced:     'bg-red-100 text-red-800 border-red-200',
};
---

<Layout
  title={guide.data.title}
  description={`Step-by-step guide: ${guide.data.title}. Device: ${guide.data.device}. Time: ${guide.data.estimatedTime}.`}
  canonical={`/guides/${guide.slug}`}
>
  <Navbar />

  <main class="min-h-screen bg-gray-50">
    <!-- Breadcrumb + header -->
    <div class="bg-white border-b border-gray-100">
      <div class="max-w-4xl mx-auto px-4 py-4">
        <nav class="text-sm text-gray-400 mb-4">
          <a href="/" class="hover:text-blue-600">Home</a>
          <span class="mx-2">/</span>
          <a href="/guides" class="hover:text-blue-600">Knowledge Base</a>
          <span class="mx-2">/</span>
          <span class="text-gray-700">{guide.data.title}</span>
        </nav>

        <h1 class="text-3xl font-bold text-gray-900 leading-tight">{guide.data.title}</h1>

        <div class="flex flex-wrap items-center gap-3 mt-4 text-sm">
          <span class={`px-3 py-1 rounded-full font-medium border text-xs ${difficultyColour[guide.data.difficulty]}`}>
            {guide.data.difficulty}
          </span>
          <span class="text-gray-500">📱 {guide.data.device}</span>
          <span class="text-gray-500">⏱ {guide.data.estimatedTime}</span>
          <span class="text-gray-400 ml-auto">Updated {guide.data.updatedAt} · {guide.data.author}</span>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 py-8 grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8">
      <!-- Main content -->
      <article class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 prose prose-blue max-w-none">
        {guide.data.warnings.length > 0 && (
          <div class="not-prose mb-6 rounded-xl border border-red-200 bg-red-50 p-4">
            <p class="font-semibold text-red-700 mb-2 flex items-center gap-1">
              <span>⚠</span> Important Warnings
            </p>
            <ul class="space-y-1.5">
              {guide.data.warnings.map(w => (
                <li class="text-sm text-red-700 flex gap-2">
                  <span class="shrink-0">•</span>
                  <span>{w}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <Content />
      </article>

      <!-- Sidebar -->
      <aside class="space-y-5">
        <!-- Parts required -->
        {guide.data.parts.length > 0 && (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
            <h3 class="font-semibold text-gray-900 mb-3 flex items-center gap-2">
              <span>🔩</span> Parts Required
            </h3>
            <ul class="space-y-2">
              {guide.data.parts.map(part => (
                <li class="text-sm">
                  <span class="font-medium text-gray-800">{part.name}</span>
                  <br />
                  <code class="text-xs text-gray-400">{part.sku}</code>
                </li>
              ))}
            </ul>
            <a
              href="/repairs"
              class="mt-4 block w-full text-center bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2.5 rounded-xl transition-colors"
            >
              Book This Repair →
            </a>
          </div>
        )}

        <!-- Tools -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
          <h3 class="font-semibold text-gray-900 mb-3 flex items-center gap-2">
            <span>🛠</span> Tools Needed
          </h3>
          <ul class="space-y-1.5">
            {guide.data.tools.map(tool => (
              <li class="text-sm text-gray-600 flex gap-2">
                <span class="text-gray-300">—</span>
                {tool}
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA -->
        <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-2xl p-5 text-white text-center">
          <div class="text-3xl mb-2">💬</div>
          <p class="font-semibold mb-1">Not comfortable doing it yourself?</p>
          <p class="text-blue-200 text-sm mb-4">
            Book a repair at your nearest TechMo branch — we'll handle it for you.
          </p>
          <a
            href="/repairs"
            class="block bg-white text-blue-700 font-semibold text-sm py-2.5 rounded-xl hover:bg-blue-50 transition-colors"
          >
            Book a Repair
          </a>
        </div>
      </aside>
    </div>
  </main>

  <Footer />
</Layout>
