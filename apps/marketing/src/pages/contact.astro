---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Turnstile from '../components/Turnstile.astro';

const TURNSTILE_SITE_KEY = import.meta.env.CF_TURNSTILE_SITE_KEY ?? '';

const branches = [
  {
    name: 'TechMo Colombo 03',
    address: '45 Galle Road, Colombo 03',
    phone: '+94 11 234 5678',
    hours: 'Mon–Sat: 9am–7pm, Sun: 10am–5pm',
    mapUrl: 'https://maps.google.com/?q=Colombo+03',
  },
  {
    name: 'TechMo Nugegoda',
    address: '12 High Level Road, Nugegoda',
    phone: '+94 11 289 0123',
    hours: 'Mon–Sat: 9am–7pm, Sun: 10am–5pm',
    mapUrl: 'https://maps.google.com/?q=Nugegoda',
  },
  {
    name: 'TechMo Kandy',
    address: '78 Dalada Veediya, Kandy',
    phone: '+94 81 220 4567',
    hours: 'Mon–Sat: 9am–6pm, Closed Sunday',
    mapUrl: 'https://maps.google.com/?q=Kandy+City+Center',
  },
];
---
<Layout title="Contact Us — TechMo" description="Get in touch with TechMo Electronics. Inquire about products or repair services.">
  <Navbar />

  <!-- Header -->
  <section class="bg-gradient-to-r from-[#1e40af] to-[#2563eb] text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl font-bold mb-2">Get In Touch</h1>
      <p class="text-blue-200">Inquire about a product, book a repair, or visit us at any branch.</p>
    </div>
  </section>

  <section class="py-14 px-4 bg-white">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-12">

      <!-- Inquiry Form -->
      <div>
        <h2 class="text-2xl font-bold text-[#0f172a] mb-1">Product Inquiry / Reservation</h2>
        <p class="text-[#64748b] text-sm mb-6">
          Fill in your details and we'll reach out within 24 hours.
          All purchases are finalized in-store — no online payment.
        </p>

        <form id="contact-form" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
              <input type="text" name="name" required autocomplete="name"
                class="w-full border border-gray-200 rounded-xl px-3.5 py-2.5 text-sm
                       focus:outline-none focus:ring-2 focus:ring-[#1e40af] transition duration-150" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number *</label>
              <input type="tel" name="phone" required autocomplete="tel"
                class="w-full border border-gray-200 rounded-xl px-3.5 py-2.5 text-sm
                       focus:outline-none focus:ring-2 focus:ring-[#1e40af] transition duration-150" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email (optional)</label>
            <input type="email" name="email" autocomplete="email"
              class="w-full border border-gray-200 rounded-xl px-3.5 py-2.5 text-sm
                     focus:outline-none focus:ring-2 focus:ring-[#1e40af] transition duration-150" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Inquiry Type *</label>
            <select name="type" required
              class="w-full border border-gray-200 rounded-xl px-3.5 py-2.5 text-sm
                     focus:outline-none focus:ring-2 focus:ring-[#1e40af] transition duration-150 bg-white">
              <option value="">Select…</option>
              <option value="product_inquiry">Product Inquiry</option>
              <option value="product_reservation">Product Reservation</option>
              <option value="repair_booking">Repair Booking</option>
              <option value="warranty_claim">Warranty Claim</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Product / Item *</label>
            <input type="text" name="product" required
              placeholder="e.g. iPhone 15 Pro, Samsung screen replacement…"
              class="w-full border border-gray-200 rounded-xl px-3.5 py-2.5 text-sm
                     focus:outline-none focus:ring-2 focus:ring-[#1e40af] transition duration-150" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
            <textarea name="message" rows="4"
              placeholder="Any additional details, budget range, urgency, etc."
              class="w-full border border-gray-200 rounded-xl px-3.5 py-2.5 text-sm
                     focus:outline-none focus:ring-2 focus:ring-[#1e40af] transition duration-150 resize-none"></textarea>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Preferred Branch</label>
            <div class="flex flex-wrap gap-3">
              {branches.map((b, i) => (
                <label class="flex items-center gap-2 text-sm cursor-pointer">
                  <input type="radio" name="branch" value={b.name}
                    checked={i === 0}
                    class="text-[#1e40af] accent-[#1e40af]" />
                  {b.name.replace('TechMo ', '')}
                </label>
              ))}
            </div>
          </div>

          <!-- Cloudflare Turnstile -->
          {TURNSTILE_SITE_KEY && (
            <Turnstile sitekey={TURNSTILE_SITE_KEY} callback="onTurnstileSuccess" />
          )}
          <input type="hidden" name="turnstileToken" id="turnstile-token" />

          <button type="submit"
            class="w-full bg-[#1e40af] text-white py-3.5 rounded-xl font-semibold
                   hover:bg-[#1e3a8a] transition-colors duration-[250ms] hover:scale-[1.01] transform">
            Send Inquiry
          </button>
          <p id="form-status" class="text-center text-sm min-h-[20px]"></p>
        </form>
      </div>

      <!-- Branch Info + Quick Links -->
      <div class="space-y-6">
        <div>
          <h2 class="text-2xl font-bold text-[#0f172a] mb-4">Our Branches</h2>
          <div class="space-y-4">
            {branches.map(b => (
              <div class="bg-[#f8fafc] rounded-2xl border border-gray-100 p-5">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <h3 class="font-semibold text-[#0f172a] mb-1">{b.name}</h3>
                    <p class="text-sm text-[#64748b] mb-1">📍 {b.address}</p>
                    <p class="text-sm text-[#64748b] mb-1">📞 <a href={`tel:${b.phone}`} class="hover:text-[#1e40af]">{b.phone}</a></p>
                    <p class="text-xs text-[#64748b]">🕒 {b.hours}</p>
                  </div>
                  <a href={b.mapUrl} target="_blank" rel="noopener"
                     class="text-xs text-[#1e40af] font-semibold hover:underline flex-shrink-0">
                    Map →
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="bg-[#0f172a] rounded-2xl p-6 text-white">
          <h3 class="font-semibold mb-4">Quick Links</h3>
          <div class="space-y-3">
            {[
              { icon: '📲', text: 'Track My Repair', href: '/repair-status' },
              { icon: '📱', text: 'Browse Products', href: '/products' },
              { icon: '⭐', text: 'Loyalty Program', href: '/#loyalty' },
            ].map(l => (
              <a href={l.href}
                 class="flex items-center gap-3 text-sm text-gray-300 hover:text-white
                        hover:bg-white/5 rounded-xl px-3 py-2 -mx-3 transition-all duration-150">
                <span class="text-lg">{l.icon}</span>
                {l.text}
              </a>
            ))}
          </div>
        </div>

        <!-- Social -->
        <div class="text-center text-sm text-[#64748b]">
          <p class="mb-3 font-medium text-[#0f172a]">Follow Us</p>
          <div class="flex justify-center gap-4">
            {[
              { name: 'Facebook', href: '#', icon: '📘' },
              { name: 'Instagram', href: '#', icon: '📸' },
              { name: 'WhatsApp', href: '#', icon: '💬' },
            ].map(s => (
              <a href={s.href}
                 class="flex items-center gap-1.5 hover:text-[#1e40af] transition-colors">
                {s.icon} {s.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  // Turnstile callback
  (window as any).onTurnstileSuccess = (token: string) => {
    const el = document.getElementById('turnstile-token') as HTMLInputElement | null;
    if (el) el.value = token;
  };

  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const status = document.getElementById('form-status')!;

    btn.disabled = true;
    btn.textContent = 'Sending…';
    status.textContent = '';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData) as Record<string, string>;

    try {
      const res = await fetch(
        `${import.meta.env.PUBLIC_GATEWAY_URL || ''}/api/v1/mailer/contact-inquiry`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: data.name,
            email: data.email ?? undefined,
            phone: data.phone,
            inquiryType: data.type,
            product: data.product,
            message: data.message,
            branch: data.branch,
            turnstileToken: data.turnstileToken,
          }),
        }
      );
      if (res.ok) {
        status.textContent = '✅ Inquiry sent! We\'ll contact you within 24 hours.';
        status.className = 'text-center text-sm text-green-600 font-medium';
        form.reset();
      } else {
        const err = await res.json().catch(() => ({}));
        throw new Error((err as any).message ?? 'server error');
      }
    } catch (err: any) {
      status.textContent = `❌ ${err.message ?? 'Failed to send. Please call us or visit a branch directly.'}`;
      status.className = 'text-center text-sm text-red-500';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Inquiry';
    }
  });
</script>
