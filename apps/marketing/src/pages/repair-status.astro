---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const token = Astro.url.searchParams.get('token') ?? '';
const GATEWAY = import.meta.env.GATEWAY_URL ?? 'http://localhost:3001';

let repairData: any = null;
let lookupError = false;

if (token) {
  try {
    const res = await fetch(
      `${GATEWAY}/api/v1/repairs/track/${encodeURIComponent(token)}`,
      { headers: { 'x-internal-request': '1' } }
    );
    if (res.ok) {
      repairData = await res.json();
    } else if (res.status !== 404) {
      lookupError = true;
    }
  } catch {
    lookupError = true;
  }
}

const STATUS_INFO: Record<string, { label: string; color: string; icon: string; desc: string }> = {
  PENDING_DIAGNOSIS:  { label: 'Pending Diagnosis',   color: 'bg-gray-100 text-gray-600 border-gray-200',     icon: '🔍', desc: 'Your device has been received and is awaiting initial diagnosis.' },
  AWAITING_PARTS:     { label: 'Awaiting Parts',       color: 'bg-amber-100 text-amber-700 border-amber-200',  icon: '📦', desc: 'We\'ve ordered the required parts. Your repair will continue once they arrive.' },
  UNDER_REPAIR:       { label: 'Under Repair',         color: 'bg-blue-100 text-blue-700 border-blue-200',     icon: '🔧', desc: 'Our technician is actively working on your device.' },
  READY_FOR_PICKUP:   { label: 'Ready for Pickup',     color: 'bg-green-100 text-green-700 border-green-200',  icon: '✅', desc: 'Your device is repaired and ready. Please collect it at your earliest convenience.' },
  COMPLETED:          { label: 'Completed',            color: 'bg-green-100 text-green-700 border-green-200',  icon: '🎉', desc: 'Repair completed and device collected. Thank you for choosing TechMo!' },
  CANCELLED:          { label: 'Cancelled',            color: 'bg-red-100 text-red-700 border-red-200',        icon: '❌', desc: 'This repair has been cancelled. Please contact us for more information.' },
};

const STATUS_ORDER = ['PENDING_DIAGNOSIS', 'AWAITING_PARTS', 'UNDER_REPAIR', 'READY_FOR_PICKUP', 'COMPLETED'];

const currentInfo = repairData ? (STATUS_INFO[repairData.status] ?? { label: repairData.status, color: 'bg-gray-100 text-gray-600 border-gray-200', icon: '❓', desc: '' }) : null;
const currentStep = repairData ? STATUS_ORDER.indexOf(repairData.status) : -1;

// Pre-compute per-step data in frontmatter to avoid Astro JSX parser issues
// with block-body arrow functions that contain comparison operators.
const statusStepItems = STATUS_ORDER.map((status, idx) => {
  const info = STATUS_INFO[status];
  const isDone = currentStep > idx || (repairData?.status === 'COMPLETED' && idx <= 4);
  const isCurrent = repairData?.status === status;
  const isCancelled = repairData?.status === 'CANCELLED';
  return { status, idx, info, isDone, isCurrent, isCancelled };
});
---
<Layout title="Track My Repair — TechMo" description="Track your device repair status in real time using your ticket number or QR code.">
  <Navbar />

  <!-- Header -->
  <section class="bg-gradient-to-r from-[#0f172a] to-[#1e3a8a] text-white py-14 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <div class="text-5xl mb-3">📲</div>
      <h1 class="text-4xl font-bold mb-2">Track Your Repair</h1>
      <p class="text-blue-200">Enter your QR token or ticket number to see your repair status in real time.</p>
    </div>
  </section>

  <!-- Search Form -->
  <section class="py-12 px-4 bg-white">
    <div class="max-w-xl mx-auto">
      <form method="GET" action="/repair-status" class="bg-[#f8fafc] rounded-2xl border border-gray-100 p-7 shadow-sm">
        <label class="block text-sm font-semibold text-[#0f172a] mb-2">
          Ticket Number or QR Token
        </label>
        <div class="flex gap-3">
          <input
            type="text"
            name="token"
            value={token}
            placeholder="e.g. RPR-2024-00123"
            class="flex-1 border border-gray-200 rounded-xl px-4 py-3 text-sm
                   focus:outline-none focus:ring-2 focus:ring-[#1e40af] transition duration-150"
            required
            autofocus={!token}
          />
          <button type="submit"
            class="bg-[#1e40af] text-white px-6 py-3 rounded-xl font-semibold text-sm
                   hover:bg-[#1e3a8a] transition-colors duration-[250ms] flex-shrink-0">
            Track
          </button>
        </div>
        <p class="text-xs text-[#64748b] mt-2">
          Your ticket number is on your receipt (format: RPR-YYYY-00123) or scan the QR code from your receipt.
        </p>
      </form>

      {lookupError && (
        <div class="mt-5 bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 text-sm">
          ⚠️ Could not reach the server. Please try again later or call us directly.
        </div>
      )}

      {token && !repairData && !lookupError && (
        <div class="mt-5 bg-amber-50 border border-amber-200 text-amber-700 rounded-xl p-4 text-sm">
          🔍 No repair found for <strong>{token}</strong>. Please check the ticket number and try again.
        </div>
      )}
    </div>
  </section>

  <!-- Repair Status Result -->
  {repairData && currentInfo && (
    <section class="py-8 px-4 bg-[#f8fafc] pb-16">
      <div class="max-w-2xl mx-auto space-y-6">

        <!-- Status Card -->
        <div class={`rounded-2xl border-2 p-6 ${currentInfo.color}`}>
          <div class="flex items-center gap-4 mb-3">
            <div class="text-4xl">{currentInfo.icon}</div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest opacity-70">Current Status</p>
              <h2 class="text-2xl font-bold">{currentInfo.label}</h2>
            </div>
          </div>
          <p class="text-sm">{currentInfo.desc}</p>
        </div>

        <!-- Repair Details -->
        <div class="bg-white rounded-2xl border border-gray-100 p-6">
          <h3 class="font-semibold text-[#0f172a] mb-4">Repair Details</h3>
          <div class="space-y-3">
            {[
              { label: 'Ticket Number', value: repairData.ticketNumber },
              { label: 'Device', value: [repairData.deviceBrand, repairData.deviceModel].filter(Boolean).join(' ') || 'N/A' },
              { label: 'Issue', value: repairData.issue },
              { label: 'Technician Notes', value: repairData.technicianNotes ?? 'Not yet added' },
              { label: 'Estimated Completion', value: repairData.estimatedCompletionDate
                  ? new Date(repairData.estimatedCompletionDate).toLocaleDateString('en-LK', { dateStyle: 'medium' })
                  : 'TBD' },
              { label: 'Created', value: repairData.createdAt
                  ? new Date(repairData.createdAt).toLocaleDateString('en-LK', { dateStyle: 'medium' })
                  : 'N/A' },
            ].filter(r => r.value).map(row => (
              <div class="flex justify-between text-sm border-b border-gray-50 pb-2 last:border-0 last:pb-0">
                <span class="text-[#64748b]">{row.label}</span>
                <span class="font-medium text-[#0f172a] text-right max-w-[60%]">{row.value}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Status Timeline -->
        <div class="bg-white rounded-2xl border border-gray-100 p-6">
          <h3 class="font-semibold text-[#0f172a] mb-5">Repair Progress</h3>
          <div class="relative">
            {statusStepItems.map(({ idx, info, isDone, isCurrent, isCancelled }) => (
              <div class="flex gap-4 mb-5 last:mb-0">
                <div class="flex flex-col items-center">
                  <div class={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0 border-2
                               ${isCurrent && !isCancelled
                                 ? 'bg-[#1e40af] border-[#1e40af] text-white'
                                 : isDone && !isCancelled
                                 ? 'bg-[#16a34a] border-[#16a34a] text-white'
                                 : 'bg-gray-100 border-gray-200 text-gray-400'}`}>
                    {isDone && !isCurrent && !isCancelled ? '✓' : info.icon}
                  </div>
                  {idx < STATUS_ORDER.length - 1 && (
                    <div class={`w-0.5 flex-1 mt-1 min-h-[24px] ${isDone && !isCancelled ? 'bg-[#16a34a]' : 'bg-gray-100'}`}></div>
                  )}
                </div>
                <div class="pt-1 pb-5 last:pb-0">
                  <p class={`text-sm font-semibold ${isCurrent ? 'text-[#1e40af]' : isDone ? 'text-[#0f172a]' : 'text-gray-400'}`}>
                    {info.label}
                  </p>
                  {isCurrent && <p class="text-xs text-[#64748b] mt-0.5">{info.desc}</p>}
                </div>
              </div>
            ))}

            {repairData.status === 'CANCELLED' && (
              <div class="flex gap-4 mt-2">
                <div class="w-8 h-8 rounded-full bg-red-100 border-2 border-red-300 flex items-center justify-center text-sm">❌</div>
                <div class="pt-1">
                  <p class="text-sm font-semibold text-red-600">Cancelled</p>
                  <p class="text-xs text-[#64748b] mt-0.5">{STATUS_INFO.CANCELLED.desc}</p>
                </div>
              </div>
            )}
          </div>
        </div>

        <!-- History Log -->
        {repairData.history?.length > 0 && (
          <div class="bg-white rounded-2xl border border-gray-100 p-6">
            <h3 class="font-semibold text-[#0f172a] mb-4">Activity Log</h3>
            <div class="space-y-3">
              {[...repairData.history].reverse().map((entry: any) => (
                <div class="flex gap-3 text-sm">
                  <span class="text-[#64748b] flex-shrink-0">
                    {new Date(entry.changedAt).toLocaleDateString('en-LK', { month: 'short', day: 'numeric' })}
                  </span>
                  <div>
                    <span class="font-medium text-[#0f172a]">{entry.toStatus?.replace(/_/g, ' ')}</span>
                    {entry.notes && <p class="text-[#64748b] mt-0.5">{entry.notes}</p>}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="text-center">
          <p class="text-sm text-[#64748b]">
            Questions about your repair? <a href="/contact" class="text-[#1e40af] font-semibold hover:underline">Contact us</a>
          </p>
        </div>
      </div>
    </section>
  )}

  <!-- Help Section (when no result) -->
  {!repairData && (
    <section class="py-12 px-4 bg-[#f8fafc]">
      <div class="max-w-2xl mx-auto grid sm:grid-cols-3 gap-5">
        {[
          { icon: '🧾', title: 'Check Your Receipt', desc: 'Your ticket number is printed on your repair receipt in the format RPR-YYYY-NNNNN.' },
          { icon: '📷', title: 'Scan the QR Code', desc: 'Point your phone camera at the QR code on your receipt to auto-fill the tracking form.' },
          { icon: '📞', title: 'Call Us Directly', desc: 'Can\'t find your ticket? Call your nearest TechMo branch and we\'ll look it up for you.' },
        ].map(tip => (
          <div class="bg-white rounded-2xl border border-gray-100 p-5">
            <div class="text-3xl mb-3">{tip.icon}</div>
            <h3 class="font-semibold text-[#0f172a] text-sm mb-1">{tip.title}</h3>
            <p class="text-xs text-[#64748b] leading-relaxed">{tip.desc}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <Footer />
</Layout>
