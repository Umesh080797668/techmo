# ──────────────────────────────────────────────
# TechMo Marketing Site — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Public site URL (used for og:url and canonical tags)
SITE_URL=https://techmo.lk

# URL of the Customer Portal app (used in Navbar "My Account" link and Footer)
PUBLIC_CUSTOMER_PORTAL_URL=http://localhost:4002

# ── Cloudflare Web Analytics ─────────────────
# Get your token from: Cloudflare Dashboard > Web Analytics
CF_ANALYTICS_TOKEN=

# ── Cloudflare Turnstile (bot protection) ────
# Get keys from: Cloudflare Dashboard > Turnstile
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Cloudflare Tunnel ────────────────────────
# Get token from: Cloudflare Zero Trust > Tunnels
CF_TUNNEL_TOKEN=
