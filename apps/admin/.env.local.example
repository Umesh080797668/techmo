# Admin Portal — Local Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# ── Gateway ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000

# ── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:4001
NEXT_PUBLIC_CUSTOMER_URL=http://localhost:4002
NEXT_PUBLIC_MARKETING_URL=http://localhost:4000

# ── Google Reviews ────────────────────────────────────────────────────────────
# Find this at: https://business.google.com → Get more reviews → Share review form
NEXT_PUBLIC_GOOGLE_REVIEW_URL=https://g.page/r/XXXXXXXXXXXXXXXX/review

# ── Error Tracking (GlitchTip / Sentry) ──────────────────────────────────────
# Set up a project at your self-hosted GlitchTip instance (port 8010)
NEXT_PUBLIC_GLITCHTIP_DSN=

# ── Worker Service (PDF / QR generation) ─────────────────────────────────────
NEXT_PUBLIC_WORKER_URL=http://localhost:8000

# ── Cloudinary ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ── Versioning (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_VERSION=admin@dev
