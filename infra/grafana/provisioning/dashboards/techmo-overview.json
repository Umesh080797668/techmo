{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HTTP Request Rate (all services)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{
        "expr": "sum(rate(http_requests_total[5m]))",
        "legendFormat": "req/s"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HTTP 5xx Error Rate",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m]))",
        "legendFormat": "errors/s"
      }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Repairs",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "expr": "techmo_active_repairs_total",
        "legendFormat": "active repairs"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Today's POS Revenue (LKR)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{
        "expr": "techmo_pos_revenue_today_lkr",
        "legendFormat": "LKR"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Requests per Service (5m rate)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "sum by(job) (rate(http_requests_total[5m]))",
        "legendFormat": "{{job}}"
      }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "p99 Latency per Service",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum by(job, le) (rate(http_request_duration_seconds_bucket[5m])))",
        "legendFormat": "{{job}} p99"
      }]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Application Logs (Loki)",
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "targets": [{
        "expr": "{app=~\"techmo.*\"} |= ``",
        "legendFormat": ""
      }],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "PostgreSQL Active Connections",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 22 },
      "targets": [{
        "expr": "pg_stat_activity_count",
        "legendFormat": "connections"
      }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Redis Memory Usage",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 22 },
      "targets": [{
        "expr": "redis_memory_used_bytes / 1024 / 1024",
        "legendFormat": "Memory MB"
      }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["techmo", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Colombo",
  "title": "TechMo — System Overview",
  "uid": "techmo-overview",
  "version": 1
}
