# ─────────────────────────────────────────────────────────────────────────────
# TechMo Enterprise Retail & Service Management System
# Environment Variables – copy to .env and fill in real values
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
DB_USER=techmo
DB_PASSWORD=techmo_secret

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong 256+ bit secret: openssl rand -hex 64
JWT_SECRET=change_me_to_a_very_long_secret_key_at_least_64_chars_long_please
JWT_EXPIRY_MS=900000         # 15 minutes
JWT_REFRESH_EXPIRY_MS=604800000   # 7 days

# ── NodeMailer (SMTP) ──────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@techmo.lk
ALERT_EMAIL=admin@techmo.lk

# ── Cloudinary (media & PDF storage) ─────────────────────────────────────────────────────
# Sign up free at https://cloudinary.com – 25 GB free storage + 25 GB bandwidth/month
# Go to Dashboard → copy Cloud name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=techmo_uploads   # create unsigned preset in Cloudinary Settings

# ── Cloudflare Tunnel (secure HTTPS access without port forwarding) ──────────
# Create a tunnel at: https://one.dash.cloudflare.com → Zero Trust → Tunnels
# The tunnel exposes the gateway + marketing site to the internet securely.
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ── Cloudflare Turnstile (bot/spam protection for public forms) ───────────────
# Create widget at: https://dash.cloudflare.com → Turnstile
# Use "Managed" mode for invisible protection (no user challenge in most cases)
CF_TURNSTILE_SITE_KEY=your_turnstile_site_key
CF_TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ── Cloudflare Web Analytics ──────────────────────────────────────────────────
# Enable in Cloudflare dashboard → Analytics → Web Analytics
# Cookie-free, GDPR-compliant — no consent banner needed
CF_ANALYTICS_TOKEN=your_cf_analytics_beacon_token

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PUBLIC_GATEWAY_URL=http://localhost:3000
